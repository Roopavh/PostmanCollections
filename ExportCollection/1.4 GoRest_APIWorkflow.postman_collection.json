    {
      "name": "2-CreateAUser",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "const user_id = response.id;",
              "console.log(\"user id===>\" + user_id);",
              "pm.variables.set(\"userID\", user_id);",
              "//local variable: userID",
              "",
              "//LDECG",
              "",
              "//test cases:",
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"check user name is Roopa\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(\"Roopa\");",
              "});",
              "",
              "pm.test(\"Content-Type is present\", function () {",
              "    pm.response.to.have.header(\"Content-Type\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{tokenID}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"Roopa\",\r\n    \"email\": \"roopa_{{$randomEmail}}\",\r\n    \"gender\": \"male\",\r\n    \"status\": \"active\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}/public/v2/users",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "public",
            "v2",
            "users"
          ]
        }
      },
      "response": []
    },
    {
